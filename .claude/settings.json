{
  "permissions": {
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "node ~/claude/.claude/statusline-command.js"
  },
  "language": "한국어",
  "effortLevel": "high",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "cd ~/claude && git pull --ff-only --quiet 2>/dev/null && git submodule update --remote --quiet 2>/dev/null; true",
            "timeout": 10,
            "statusMessage": "claude 설정 동기화 중..."
          }
        ]
      }
    ]
  }
}
